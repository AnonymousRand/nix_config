/* the primary goal of this file is to override most of the built-in GTK (libadwaita) CSS variables 
 * which should hopefully make our life slightly easier :3 */
/******************************************************************************/
/* variables                                                                  */
/******************************************************************************/
:root {
  /**************************************************************************/
  /* basics                                                                 */
  /*
   * by default, GTK apps are rendered with libadwaita, whose src/stylesheet/_colors.scss
   * (https://github.com/GNOME/libadwaita/blob/42f647ffcbec3282c126ad9153c77baecf86ba90/src/stylesheet/_colors.scss#L270)
   * very frustratingly sets a bunch of defaults, such as using `currentColor` (the *foreground* color)
   * mixed with varying amounts of `transparent` to define the selected tab etc. *background* colors.
   *
   * what the fuck.
   *
   * so here's my attempt to make it somewhat make sense.
   */
  --default-fg: #cccccc;
  --default-bg: #000000;
  --variant-fg: #a8a8a8;
  --variant-bg: #202020;
  --selection-fg: #000000;
  --selection-bg: #ffcbe6;
  --error: #ff0000;
  --accent-default-fg: #505050;
  --accent-default-bg: #ffcbe6;
  --hover-default-fg: #cccccc;
  --hover-default-bg: #2a2a2a;
  --disabled-opacity: 50%;
  --link: #00eaff;
  --link-hover: #66f2ff;
  --link-visited: #66f2ff;
}

/******************************************************************************/
/* placeholders                                                               */
/******************************************************************************/
menubutton, splitbutton, button,
tab {
  /* to use these variables, simply set ``--normal-bg`` within the selector scope,
   * and the other variables will automatically populate (you can still change them, of course) */
  --hover-bg: hsl(from var(--normal-bg) h s calc(l - 2%));
  --active-bg: hsl(from var(--normal-bg) h s calc(l - 6.5%));
  background-color: var(--normal-bg);
  color: var(--normal-fg);
}
menubutton:hover, splitbutton:hover, button:hover,
tab:hover {
  background-color: var(--hover-bg);
  color: var(--normal-fg);
}
menubutton:active, splitbutton:active, button:active,
tab:active {
  background-color: var(--active-bg);
  color: var(--normal-fg);
}
menubutton.flat, splitbutton.flat {
  --normal-fg: inherit;
  --normal-bg: inherit;
}

menubutton.raised, splitbutton.raised {
  --normal-fg: var(--accent-default-fg);
  --normal-bg: var(--accent-default-bg);
}

menubutton:selected, splitbutton:selected {
  --normal-fg: var(--accent-default-fg);
  --normal-bg: var(--accent-default-bg);
}

/******************************************************************************/
/* styles                                                                     */
/******************************************************************************/
/******************************************************************************/
/* variables                                                                  */
/******************************************************************************/
:root {
  /**************************************************************************/
  /* accents                                                                */
  --accent-fg-color: var(--accent-default-fg);
  --accent-bg-color: var(--accent-default-bg);
  --accent-blue: #00eaff
  --accent-green: #8cff00
  --accent-orange: #ffd500
  --accent-pink: #ffcbe6
  --accent-purple: #ffadd6
  --accent-red: #ff0000
  --accent-slate: #505050
  --accent-teal: #00bbff
  --accent-yellow: #ffdb26
  /**************************************************************************/
  /* GNOME palette                                                          */

  --blue-1: #66f2ff
  --blue-2: #00eaff
  --blue-3: #00caff
  --blue-4: #00bbff
  --blue-5: #00a6ff
  --green-1: #a3ff33
  --green-2: #8cff00
  --green-3: #8cff00
  --green-4: #76d600
  --green-5: #6fc900
  --orange-1: #ffdb26
  --orange-2: #ffd500
  --orange-3: #ffbf00
  --orange-4: #ffa600
  --orange-5: #ff9500
  --purple-1: #ffb3ff
  --purple-2: #ff66ff
  --purple-3: #ff00ff
  --purple-4: #e600e6
  --purple-5: #cc00cc
  --red-1: #ff5959
  --red-2: #ff3333
  --red-3: #ff0000
  --red-4: #e60000
  --red-5: #cc0000
  --yellow-1: #ffdf40
  --yellow-2: #ffdb26
  --yellow-3: #ffd500
  --yellow-4: #ffbf00
  --yellow-5: #ffa600
  /**************************************************************************/
  /* UI elements                                                            */
  --active-toggle-fg-color: var(--accent-default-fg);
  --active-toggle-bg-color: var(--accent-default-bg);
  --border-color: #ffadd6;
  --border-opacity: 1;
  --card-fg-color: var(--variant-fg);
  --card-bg-color: var(--variant-bg);
  --dialog-fg-color: var(--variant-fg);
  --dialog-bg-color: var(--variant-bg);
  --headerbar-fg-color: var(--variant-fg);
  --headerbar-bg-color: var(--variant-bg);
  --headerbar-backdrop-color: var(--headerbar-bg-color); /* overlay that is blended onto unfocused headerbars */
  --overview-fg-color: var(--default-fg);
  --overview-bg-color: var(--default-bg);
  --popover-fg-color: var(--variant-fg);
  --popover-bg-color: var(--variant-bg);
  /* now why the heck do *you* exist ;-; */
  --secondary-sidebar-fg-color: var(--secondary-sidebar-fg-color);
  --secondary-sidebar-bg-color: hsl(from var(--sidebar-bg-color) h s calc(l + 1.5%));
  --secondary-sidebar-backdrop-color: var(--sidebar-bg-color);
  --sidebar-fg-color: var(--variant-fg);
  --sidebar-bg-color: var(--variant-bg);
  --sidebar-backdrop-color: var(--sidebar-bg-color);
  --view-fg-color: var(--variant-fg);
  --view-bg-color: var(--variant-bg);
  --window-fg-color: var(--default-fg);
  --window-bg-color: var(--default-bg);
  /**************************************************************************/
  /* misc                                                                   */
  --destructive-color: #ff0000;
  --destructive-fg-color: #561d26;
  --destructive-bg-color: var(--destructive-color);
  --error-color: #ff0000;
  --error-fg-color: #561d26;
  --error-bg-color: var(--error-color);
  --success-color: #8cff00;
  --success-fg-color: #8cff00;
  --success-bg-color: var(--success-color);
  --warning-color: #ffbf00;
  --warning-fg-color: var(--default-fg);
  --warning-bg-color: var(--warning-color);
}

/******************************************************************************/
/* styles                                                                     */
/******************************************************************************/
splitbutton:hover {
  background-color: hsl(from var(--hover-bg) h s calc(l + 1.5%));
  color: var(--hover-fg);
}

popover.menu modelbutton:hover {
  background-color: var(--hover-bg);
  color: var(--hover-fg);
}

/* titlebar tab should not be highlighted as if it were a selected tab if it's the only tab */
tabbox.single-tab tab {
  background: none;
}

