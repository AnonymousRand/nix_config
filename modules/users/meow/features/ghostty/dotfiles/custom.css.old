@import url("../theme/gtk_base.css")

/******************************************************************************/
/* titlebar                                                                   */
/******************************************************************************/

/*
 * by default, the titlebar is rendered by adwaita, whose src/stylesheet/_colors.scss
 * (https://github.com/GNOME/libadwaita/blob/42f647ffcbec3282c126ad9153c77baecf86ba90/src/stylesheet/_colors.scss#L270)
 * very frustratingly sets a bunch of defaults, such as using `currentColor` (the *foreground* color)
 * mixed with varying amounts of `transparent` to define the selected tab etc. *background* colors.
 *
 * what the fuck.
 *
 * so here's my attempt to make it somewhat more sane.
 */

button:hover, tabbox:not(.single-tab) tab:hover {
    background-color: @btn_hover_bg;
    color:            @btn_fg;
}

button:active, tabbox:not(.single-tab) tab:active {
    background-color: @btn_active_bg;
    color:            @btn_fg;
}

button:selected, tabbox:not(.single-tab) tab:selected {
    background-color: @btn_selected_bg;
    color:            @btn_fg;
}

button:selected:hover, tabbox:not(.single-tab) tab:selected:hover {
    background-color: @btn_selected_hover_bg;
    color:            @btn_fg;
}

button:selected:active, tabbox:not(.single-tab) tab:selected:active {
    background-color: @btn_selected_active_bg;
    color:            @btn_fg;
}

button:checked {
    background-color: @btn_checked_bg;
    color:            @btn_fg;
}

splitbutton:hover {
    background-color: hsl(from @btn_hover_bg h s calc(l + 1%));
    color:            @btn_fg;
}

popover.menu modelbutton:hover {
    background-color: @selection_bg;
    color:            @selection_fg;
}

tabbox.single-tab tab {
    background: none;
}
